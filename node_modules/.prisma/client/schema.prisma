datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String? // hashed
  role      String    @default("CUSTOMER") // CUSTOMER or ADMIN
  image     String?
  phone     String?
  addresses Address[]
  orders    Order[]
  designs   Design[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Address {
  id        String  @id @default(cuid())
  user      User    @relation(fields: [userId], references: [id])
  userId    String
  label     String // Home, Office, etc
  street    String
  city      String
  state     String
  pincode   String
  phone     String
  isDefault Boolean @default(false)
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  products    Product[]
  templates   Template[]
  order       Int        @default(0)
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String
  category    Category         @relation(fields: [categoryId], references: [id])
  categoryId  String
  images      String // Stored as comma-separated or JSON string for SQLite
  basePrice   Float // starting price
  variants    ProductVariant[]
  specs       String? // JSON string for additional specs
  isActive    Boolean          @default(true)
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  designs     Design[]
}

model ProductVariant {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id])
  productId String
  name      String // e.g., "A4 Glossy", "A5 Matte"
  price     Float
  paperType String?
  finish    String?
  size      String?
  isActive  Boolean @default(true)
}

model Template {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String
  thumbnail  String
  designData String // Fabric.js canvas JSON as string
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Design {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  name       String?
  product    Product? @relation(fields: [productId], references: [id])
  productId  String?
  designData String // Fabric.js canvas JSON as string
  thumbnail  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique // e.g., "PO-2024-0001"
  user            User?       @relation(fields: [userId], references: [id])
  userId          String?
  email           String // for guest orders
  items           OrderItem[]
  shippingLabel   String?
  shippingStreet  String?
  shippingCity    String?
  shippingState   String?
  shippingPincode String?
  shippingPhone   String?
  subtotal        Float
  shippingCost    Float       @default(0)
  total           Float
  discount        Float       @default(0)
  coupon          String?
  status          String      @default("PENDING")
  paymentId       String? // Razorpay payment ID
  paymentStatus   String? // paid, pending, failed
  notes           String?
  adminNotes      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  order       Order   @relation(fields: [orderId], references: [id])
  orderId     String
  productId   String?
  productName String // snapshot
  variantName String? // snapshot
  quantity    Int
  price       Float
  designData  String? // snapshot of custom design as JSON string
  files       String? // uploaded file URLs as comma-separated list
  specs       String? // specs as JSON string
}

model Payment {
  id         String   @id @default(cuid())
  orderId    String
  razorpayId String?
  amount     Float
  currency   String   @default("INR")
  status     String // created, authorized, captured, failed
  method     String?
  createdAt  DateTime @default(now())
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  client      String?
  category    String?
  description String
  images      String // comma-separated
  tags        String // comma-separated
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  file      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
